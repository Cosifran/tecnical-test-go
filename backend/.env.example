# IoT Fleet Monitoring — Environment Variables
# Copy this file to .env and fill in the values.

# JWT signing secret. MUST be at least 32 characters (256 bits).
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-32-characters-long

# SQLite database file path. Use ":memory:" for testing.
DB_PATH=fleet.db

# HTTP server port.
PORT=8080

# Bcrypt cost factor for password hashing. Minimum: 10.
BCRYPT_COST=12

# Access token lifetime in minutes.
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=7